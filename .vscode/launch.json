{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run App on Port",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/multi_user_web.cjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "HOST": "0.0.0.0",
        "PORT": "${input:appPort}"
      },
      "serverReadyAction": {
        "pattern": "Multi-user web aktif pada .*:(\\d+)",
        "uriFormat": "http://127.0.0.1:%s",
        "action": "openExternally"
      }
    }
  ],
  "inputs": [
    {
      "id": "appPort",
      "type": "promptString",
      "description": "Port yang dipakai app",
      "default": "3000"
    }
  ]
}
